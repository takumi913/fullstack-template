# 服务器配置
SERVER_PORT=1323
SERVER_HOST=0.0.0.0

# 数据库配置
DB_DRIVER=sqlite
DB_PATH=app.db

# 如果使用MySQL
# DB_DRIVER=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=password
# DB_NAME=go_react_template

# 如果使用PostgreSQL
# DB_DRIVER=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=password
# DB_NAME=go_react_template
# DB_SSLMODE=disable

# SESSION 配置
SESSION_SECRET=your-secret-key
SESSION_EXPIRE_HOUR=24

# Creem 支付配置（推荐）
CREEM_API_KEY=creem_xxxxx
CREEM_WEBHOOK_SECRET=whsec_xxxxx
CREEM_PRODUCT_ID=prod_xxxxx
CREEM_SUCCESS_URL=http://localhost:5173/dashboard?payment=success
CREEM_TEST_MODE=true

# Stripe 支付配置（备用）
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx
# STRIPE_SUCCESS_URL=http://localhost:5173/dashboard?payment=success
# STRIPE_CANCEL_URL=http://localhost:5173/dashboard?payment=cancelled

# Bltcy AI 配置（OpenAI兼容，付费）
BLTCY_API_KEY=sk-xxxxx
BLTCY_BASE_URL=https://api.bltcy.ai/v1
BLTCY_MODEL=nano-banana

# Grok AI 配置（OpenAI兼容，免费）
GROK_API_KEY=your-grok-api-key
GROK_BASE_URL=https://gork2api.zeabur.app
GROK_MODEL=grok-4.1